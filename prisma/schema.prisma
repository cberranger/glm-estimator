// This is your Prisma schema file,
// Professional Construction Estimating Database
// Based on CSI MasterFormat structure

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// CSI MasterFormat Divisions
model Division {
  id            String   @id @default(cuid())
  divisionCode  String   @unique // e.g., "01", "02", "03"
  divisionName  String
  divisionTitle String?
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  categories    Category[]
  
  @@index([sortOrder])
}

// Categories within divisions
model Category {
  id              String    @id @default(cuid())
  divisionId      String
  categoryName    String
  parentCategoryId String?
  sortOrder       Int       @default(0)
  description     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  division        Division  @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  parentCategory  Category? @relation("CategoryHierarchy", fields: [parentCategoryId], references: [id])
  subCategories   Category[] @relation("CategoryHierarchy")
  workItems       WorkItem[]
  
  @@index([divisionId, sortOrder])
  @@index([parentCategoryId])
}

// Work Items - Construction tasks
model WorkItem {
  id                String   @id @default(cuid())
  categoryId        String
  workItemName      String
  workItemType      String?  // assembly, task, material
  scopeNotes        String?
  minimumJobCharge  Float    @default(0)
  sourcePublication String   @default("National Construction Estimator")
  sourceYear        Int      @default(2024)
  sourcePage        Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  category          Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  lineItems         LineItem[]
  
  @@index([categoryId])
}

// Line Items - Detailed cost items
model LineItem {
  id             String   @id @default(cuid())
  workItemId     String?
  description    String
  unitId         String?
  laborCodeId    String?
  laborHours     Float?
  crewCodeId     String?
  materialCost   Float    @default(0)
  laborCost      Float    @default(0)
  equipmentCost  Float    @default(0)
  totalCost      Float    @default(0)
  isActive       Boolean  @default(true)
  effectiveDate  DateTime @default(now())
  expiryDate     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  workItem       WorkItem?      @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  unit           Unit?          @relation(fields: [unitId], references: [id])
  laborCode      LaborCode?     @relation("LineItemLabor", fields: [laborCodeId], references: [id])
  crewCode       LaborCode?     @relation("LineItemCrew", fields: [crewCodeId], references: [id])
  specifications Specification[]
  variantCosts   LineItemVariantCost[]
  estimateItems  EstimateLineItem[]
  
  @@index([materialCost, laborCost, equipmentCost])
}

// Material Variants - Different grades/qualities
model MaterialVariant {
  id            String   @id @default(cuid())
  variantName   String
  description   String?
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  variantCosts  LineItemVariantCost[]
  estimateItems EstimateLineItem[]
}

// Line Item Variant Costs - Costs by variant
model LineItemVariantCost {
  id             String   @id @default(cuid())
  lineItemId     String
  variantId      String
  materialCost   Float
  laborCost      Float    @default(0)
  equipmentCost  Float    @default(0)
  totalCost      Float    @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  lineItem       LineItem       @relation(fields: [lineItemId], references: [id], onDelete: Cascade)
  variant        MaterialVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  
  @@unique([lineItemId, variantId])
  @@index([lineItemId])
}

// Specifications for line items
model Specification {
  id           String   @id @default(cuid())
  lineItemId   String
  specType     String?
  specData     String   // JSON string
  isRequired   Boolean  @default(false)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  
  lineItem     LineItem @relation(fields: [lineItemId], references: [id], onDelete: Cascade)
  
  @@index([lineItemId])
  @@index([specType])
}

// Labor Codes - Labor classifications
model LaborCode {
  id              String   @id @default(cuid())
  laborCode       String   @unique
  codeName        String
  description     String?
  baseHourlyRate  Float?
  isCrew          Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  lineItemsAsLabor LineItem[] @relation("LineItemLabor")
  lineItemsAsCrew  LineItem[] @relation("LineItemCrew")
}

// Units of measurement
model Unit {
  id                    String   @id @default(cuid())
  unitCode              String   @unique
  unitName              String
  description           String?
  conversionFactorToBase Float?
  baseUnit              String?
  createdAt             DateTime @default(now())
  
  baseUnitRef           Unit?    @relation("UnitHierarchy", fields: [baseUnit], references: [unitCode])
  derivedUnits          Unit[]   @relation("UnitHierarchy")
  lineItems             LineItem[]
  estimateItems         EstimateLineItem[]
}

// Area Modifiers - Location-based adjustments
model AreaModifier {
  id              String   @id @default(cuid())
  modifierCode    String   @unique
  modifierName    String
  description     String?
  adjustmentType  String?  // percentage, fixed
  adjustmentValue Float?
  appliesTo       String?  // material, labor, equipment, all
  isActive        Boolean  @default(true)
  effectiveDate   DateTime @default(now())
  expiryDate      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  estimates       Estimate[]
}

// Projects
model Project {
  id            String   @id @default(cuid())
  name          String
  description   String?
  clientName    String?
  clientEmail   String?
  clientPhone   String?
  address       String?
  projectType   String   @default("renovation")
  status        String   @default("draft")
  startDate     DateTime?
  endDate       DateTime?
  totalBudget   Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  rooms         Room[]
  estimates     Estimate[]
}

// Rooms
model Room {
  id          String   @id @default(cuid())
  projectId   String
  name        String
  roomType    String
  length      Float
  width       Float
  height      Float    @default(8.0)
  floorArea   Float
  wallArea    Float
  notes       String?
  positionX   Float    @default(0)
  positionY   Float    @default(0)
  rotation    Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  lineItems   EstimateLineItem[]
}

// Estimates
model Estimate {
  id                  String   @id @default(cuid())
  projectId           String
  areaModifierId      String?
  estimateName        String
  projectName         String?
  projectLocation     String?
  estimateStatus      String   @default("draft")
  totalMaterialCost   Float    @default(0)
  totalLaborCost      Float    @default(0)
  totalEquipmentCost  Float    @default(0)
  totalCost           Float    @default(0)
  profitMargin        Float    @default(0.20)
  taxRate             Float    @default(0.08)
  notes               String?
  createdBy           String?
  completedAt         DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  
  project             Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  areaModifier        AreaModifier? @relation(fields: [areaModifierId], references: [id])
  lineItems           EstimateLineItem[]
}

// Estimate Line Items
model EstimateLineItem {
  id                      String   @id @default(cuid())
  estimateId              String
  lineItemId              String?
  variantId               String?
  roomId                  String?
  quantity                Float
  unitId                  String?
  overrideMaterialCost    Float?
  overrideLaborCost       Float?
  overrideEquipmentCost   Float?
  lineTotalMaterialCost   Float    @default(0)
  lineTotalLaborCost      Float    @default(0)
  lineTotalEquipmentCost  Float    @default(0)
  lineTotal               Float    @default(0)
  notes                   String?
  displayOrder            Int      @default(0)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  
  estimate                Estimate        @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  lineItem                LineItem?       @relation(fields: [lineItemId], references: [id])
  variant                 MaterialVariant? @relation(fields: [variantId], references: [id])
  unit                    Unit?           @relation(fields: [unitId], references: [id])
  room                    Room?           @relation(fields: [roomId], references: [id])
  
  @@index([estimateId, displayOrder])
}
